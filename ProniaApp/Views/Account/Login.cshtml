@model LoginVM

<div class="container">
    <div class="card o-hidden border-0 shadow-lg my-5">
        <div class="card-body p-0">
            <div class="row justify-content-center">
               <div class="col-lg-5 d-none d-lg-block bg-register-image"></div>
                <div class="col-lg-7">
                    <div class="p-5">
                        <div class="text-center">
                            <h1 class="h4 text-gray-900 mb-4">Login to Your Account</h1>
                        </div>

                        <form class="user" asp-controller="Account" asp-action="Login" method="post">

                            <div class="form-group row">
                                <div class="col-sm-6 mb-3 mb-sm-0">
                                    <input asp-for="UserNameOrEmail" class="form-control form-control-user" id="exampleFirstName" placeholder="Username or Email">
                                    <span asp-validation-for="UserNameOrEmail" class="text-danger" style="color:darkred"></span>
                                </div>
                                <div class="col-sm-6">
                                    <input asp-for="Password" class="form-control form-control-user" id="exampleLastName" placeholder="Password">
                                    <span asp-validation-for="Password" class="text-danger" style="color:darkred"></span>
                                </div>
                            </div>
                            <div class="form-group">
                                <div class="custom-control custom-checkbox small">
                                    <input asp-for="IsPersistent" class="custom-control-input" id="customCheck">
                                    <label class="custom-control-label" for="customCheck">
                                        IsPersistent>
                                    </label>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div asp-validation-summary="ModelOnly" class="text-danger" style="color:darkred"></div>
                            </div>
                            <button type="submit" class="btn btn-primary btn-user btn-block">
                                Login Account
                            </button>

                            <hr>
                            <a href="#" class="btn btn-google btn-user btn-block">
                                <i class="fab fa-google fa-fw"></i> Login with Google
                            </a>
                            <a href="#" class="btn btn-facebook btn-user btn-block">
                                <i class="fab fa-facebook-f fa-fw"></i> Login with Facebook
                            </a>
                        </form>

                        <hr>
                        <div class="text-center">
                            <a class="small" href="#">Forgot Password?</a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>