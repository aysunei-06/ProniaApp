
@model List<Slide>

@{
    int Count = 0;
}



<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Slide Table</h4>
                <a asp-action="Create" class="btn btn-success">Add Slide</a>
                <p class="card-description">
                    Add class <code>.table-striped</code>
                </p>
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                  No
                                </th>
                                <th>
                                     Name
                                </th>
                                  <th>
                                     Image
                                </th>
                                <th>
                                    Discount
                                </th>
                                 <th>
                                    Order
                                </th>
                                <th>
                                    Settings
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(Slide slide in Model)
                            {
                                Count++;
                                <tr>
                                    <td class="py-1">
                                        @Count
                                    </td>
                                    <td>    
										@slide.Name
                                    </td>
                                    <td>
										<img src="~/assets/images/website-images/@slide.ImageUrl" alt="image" />
                                    </td>
                                    <td>
                                        @slide.Discount
                                    </td>
                                    <td>
                                         @slide.Order
                                    </td>
                                    <td>
                                        <a asp-action="Update" asp-route-id="@slide.Id" class="btn btn-primary"><i class ="mdi mdi-border-color"></i></a>
                                        <a asp-action="Detail" asp-route-id="@slide.Id" class="btn btn-secondary">
                                            <i class="mdi mdi-comment-text"></i></a>
                                        <a asp-action="Delete" asp-route-id="@slide.Id" class="btn btn-warning"><i class="mdi mdi-close"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>