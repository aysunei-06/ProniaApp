@model Slide
<div class="card">
    <div class="card-body">
        <h4 class="card-title">Slide Details</h4>
        <hr />

        <p><strong>ID:</strong> @Model.Id</p>
        <p><strong>Name:</strong> @Model.Name</p>

        <img src="~/assets/images/website-images/@Model.ImageUrl" alt="image" style="width:250px;height:250px" />

        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Order:</strong> @Model.Order</p>

        <a asp-action="Index" class="btn btn-light">Back to List</a>
    </div>
</div>